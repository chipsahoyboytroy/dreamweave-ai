# ═══════════════════════════════════════════════════════
# DreamWeave AI — Environment Variables
# Copy this to .env.local and fill in your values
#
# REQUIRED: Only DATABASE_URL, NEXTAUTH_SECRET, and NEXTAUTH_URL are needed to run.
# All API keys are OPTIONAL — the app works without them using the built-in dream engine.
# ═══════════════════════════════════════════════════════

# ─── App (REQUIRED) ───────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-random-secret-here-generate-with-openssl-rand-base64-32

# ─── Database (REQUIRED — use Vercel Postgres / Supabase / Neon) ─────
DATABASE_URL=postgresql://user:password@host:5432/dreamweave?sslmode=require

# ─── Auth Providers (optional — needed for Google sign-in) ────
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── OpenAI (OPTIONAL — enables AI-powered interpretations) ──
# Without this, the built-in dream engine is used (no cost, no API key needed)
# OPENAI_API_KEY=sk-your-openai-api-key

# ─── Image Generation (OPTIONAL — choose one) ────────
# Option A: Fal.ai (Flux.1 — fastest)
# FAL_KEY=your-fal-api-key

# Option B: OpenAI DALL-E 3 (uses OPENAI_API_KEY above)

# ─── Audio Generation (OPTIONAL) ─────────────────────
# ELEVENLABS_API_KEY=your-elevenlabs-api-key
# ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ─── Stripe Payments (OPTIONAL — needed for credit purchases) ──
# Without this, only the 3 free dreams are available
# STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# ─── Stripe Price IDs (OPTIONAL — needed with Stripe) ─
# STRIPE_PRICE_STARTER=price_starter_id
# STRIPE_PRICE_EXPLORER=price_explorer_id
# STRIPE_PRICE_VISIONARY=price_visionary_id

# ─── Analytics (OPTIONAL) ─────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─── Rate Limiting ────────────────────────────────────
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW_MS=60000
